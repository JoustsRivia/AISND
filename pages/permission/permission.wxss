/* pages/permission/permission.wxss */
.perm { min-height: 100vh; background: var(--c-bg); padding-bottom: 48rpx; }
.hero { padding: calc(env(safe-area-inset-top) + 64rpx) var(--sp-4) 80rpx; background: var(--c-primary-grad); color: #fff; }
.brand-sub { font-size: 24rpx; opacity: .82; letter-spacing: 1rpx; }
.brand-title { font-size: 44rpx; font-weight: 700; margin-top: 12rpx; }
.brand-tip { font-size: 22rpx; opacity: .8; margin-top: 12rpx; }

.card { margin: -48rpx 40rpx 0; background: var(--c-card); border-radius: var(--r-lg); padding: var(--sp-2) var(--sp-4) var(--sp-4); box-shadow: var(--sh-card); }
.sec { padding: 24rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.sec:last-of-type { border-bottom: none; }
.sec-h { font-size: 26rpx; font-weight: 600; color: var(--c-primary); margin-bottom: 12rpx; }
.sec-b { font-size: 26rpx; color: var(--c-text-sub); line-height: 1.7; }
.li { display: block; }

.empty { text-align: center; padding: 120rpx 40rpx; }
.empty-icon { font-size: 80rpx; }
.empty-title { font-size: 30rpx; color: var(--c-text); margin-top: 16rpx; }
.empty-desc { font-size: 24rpx; color: var(--c-text-weak); margin-top: 8rpx; }
