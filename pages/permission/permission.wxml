<!-- pages/permission/permission.wxml —— 权限说明（数据范围 / 可用功能 / 审批链路） -->
<view class="perm">
  <view class="hero">
    <view class="brand-sub">SND 智慧安监系统</view>
    <view class="brand-title">{{roleName}}</view>
    <view class="brand-tip">以下为该角色的权限边界，越权操作将被服务端拦截</view>
  </view>

  <view class="card" wx:if="{{info}}">
    <view class="sec">
      <view class="sec-h">📍 数据范围</view>
      <view class="sec-b">{{info.scope}}</view>
    </view>
    <view class="sec">
      <view class="sec-h">🛠 可用功能</view>
      <view class="sec-b">
        <view class="li" wx:for="{{info.functions}}" wx:key="*this">· {{item}}</view>
      </view>
    </view>
    <view class="sec">
      <view class="sec-h">🔗 审批链路</view>
      <view class="sec-b">{{info.approval}}</view>
    </view>
  </view>

  <view class="empty" wx:else>
    <view class="empty-icon">🔒</view>
    <view class="empty-title">暂无可查看的权限说明</view>
    <view class="empty-desc">完成注册 / 角色绑定后，此处将展示对应角色权限</view>
  </view>
</view>
