<!-- pages/register/register.wxml —— 独立注册页（仅注册分支，复用 api.register） -->
<view class="login">
  <view class="hero login-hero">
    <view class="brand-sub">善工智管</view>
    <view class="brand-title">账号注册</view>
  </view>

  <view class="form-wrap">
    <view class="form card">
      <role-org-picker roles="{{roles}}" units="{{units}}" bind:change="onOrgPick" />

      <form-field label="用户名" value="{{username}}" placeholder="请输入用户名" bind:input="onUserInput" />
      <view class="pwd-field">
        <view class="pwd-input-wrap"><form-field label="密码" password="{{!showPwd}}" value="{{password}}" placeholder="请输入密码（≥8位，含大小写/数字/符号更佳）" bind:input="onPwdInput" /></view>
        <view class="pwd-eye" catchtap="togglePwd">{{showPwd ? '🙈' : '👁'}}</view>
      </view>
      <view class="pwd-strength" wx:if="{{password}}">
        <view class="pwd-bar">
          <view class="pwd-fill" style="width:{{pwdStrength * 25}}%;background:{{pwdColor}}"></view>
        </view>
        <text class="pwd-label" style="color:{{pwdColor}}">强度：{{pwdLabel}}</text>
      </view>
      <form-field label="昵称" value="{{nickname}}" placeholder="选填，默认同用户名" bind:input="onNickInput" />

      <button type="primary" loading="{{loading}}" bindtap="onRegister">注册并登录</button>

      <view class="note">🔒 小程序管理员由系统后台指派；其余角色（含专班负责人 / 项目部负责人 / 安监部管理人员）均可自助注册</view>
      <view class="forgot" bindtap="goLogin">已有账号？<text class="link">去登录</text></view>
    </view>
  </view>

  <!-- 注册成功：角色权限说明弹窗（迭代 Item 6：数据范围 + 可用功能 + 审批链路 三段式） -->
  <view class="modal-mask" wx:if="{{showSuccess}}" catchtap="noop">
    <view class="modal">
      <view class="modal-ico">✅</view>
      <view class="modal-title">注册成功</view>
      <view class="modal-sub">已为您创建账号并登录</view>
      <view class="modal-role" wx:if="{{successInfo}}">
        <text class="modal-role-tag">{{successRole}}</text>
        <view class="info-sec">
          <text class="info-h">数据范围</text>
          <text class="info-b">{{successInfo.scope}}</text>
        </view>
        <view class="info-sec">
          <text class="info-h">可用功能</text>
          <view class="info-b">
            <text class="info-li" wx:for="{{successInfo.functions}}" wx:key="*this">· {{item}}</text>
          </view>
        </view>
        <view class="info-sec">
          <text class="info-h">审批链路</text>
          <text class="info-b">{{successInfo.approval}}</text>
        </view>
      </view>
      <view class="modal-link" bindtap="goPermission">查看完整权限说明 ›</view>
      <button type="primary" bindtap="onEnter">进入工作台</button>
    </view>
  </view>
</view>
