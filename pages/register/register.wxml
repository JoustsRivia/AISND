<!-- pages/register/register.wxml —— 独立注册页（仅注册分支，复用 api.register） -->
<view class="login">
  <view class="hero login-hero">
    <view class="brand-sub">SND 智慧安监系统</view>
    <view class="brand-title">账号注册</view>
  </view>

  <view class="form-wrap">
    <view class="form card">
      <view class="form-row">
        <text class="label">角色</text>
        <picker mode="selector" range="{{roles}}" range-key="name" value="{{roleIndex}}" bindchange="onRoleChange">
          <view class="picker">{{roles[roleIndex].name}} ▾</view>
        </picker>
      </view>
      <view class="role-desc">ⓘ {{roles[roleIndex].desc}}</view>

      <view class="form-row">
        <text class="label">所属单位</text>
        <picker mode="selector" range="{{units}}" range-key="name" value="{{unitIndex}}" bindchange="onUnitChange">
          <view class="picker">{{units[unitIndex].name}} ▾</view>
        </picker>
      </view>
      <view class="form-row">
        <text class="label">机构/班组</text>
        <picker mode="selector" range="{{orgOptions}}" range-key="label" value="{{orgIndex}}" bindchange="onOrgChange">
          <view class="picker">{{orgOptions[orgIndex].label}} ▾</view>
        </picker>
      </view>

      <form-field label="用户名" value="{{username}}" placeholder="请输入用户名" bind:input="onUserInput" />
      <form-field label="密码" password="{{true}}" value="{{password}}" placeholder="请输入密码（≥8位，含大小写/数字/符号更佳）" bind:input="onPwdInput" />
      <view class="pwd-strength" wx:if="{{password}}">
        <view class="pwd-bar">
          <view class="pwd-fill" style="width:{{pwdStrength * 25}}%;background:{{pwdColor}}"></view>
        </view>
        <text class="pwd-label" style="color:{{pwdColor}}">强度：{{pwdLabel}}</text>
      </view>
      <form-field label="昵称" value="{{nickname}}" placeholder="选填，默认同用户名" bind:input="onNickInput" />

      <button type="primary" loading="{{loading}}" bindtap="onRegister">注册并登录</button>

      <view class="note">🔒 小程序管理员由系统初始化分配；其余角色（含专班负责人 / 项目部负责人 / 安监部管理人员）均可自助注册</view>
      <view class="forgot" bindtap="goLogin">已有账号？<text class="link">去登录</text></view>
    </view>
  </view>

  <!-- 注册成功：角色权限说明弹窗 -->
  <view class="modal-mask" wx:if="{{showSuccess}}" catchtap="noop">
    <view class="modal">
      <view class="modal-ico">✅</view>
      <view class="modal-title">注册成功</view>
      <view class="modal-sub">已为您创建账号并登录</view>
      <view class="modal-role">
        <text class="modal-role-tag">{{successRole}}</text>
        <text class="modal-role-tip">该角色的数据范围与操作权限已按上述说明生效；如需更高权限，请联系小程序管理员分配。</text>
      </view>
      <button type="primary" bindtap="onEnter">进入工作台</button>
    </view>
  </view>
</view>
