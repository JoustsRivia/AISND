/* pages/register/register.wxss —— 注册页（复用登录页视觉语言，类定义自包含） */
.login { padding: 0; min-height: 100vh; display: flex; flex-direction: column; background: var(--c-bg); }

.login-hero {
  padding: calc(env(safe-area-inset-top) + 96rpx) var(--sp-4) 144rpx;
  text-align: center;
  position: relative;
}
.brand-sub { color: rgba(255, 255, 255, 0.82); font-size: 24rpx; letter-spacing: 1rpx; }
.brand-title { font-size: 46rpx; font-weight: 700; margin-top: 16rpx; color: #fff; letter-spacing: 1rpx; }

.form-wrap { padding: 0 40rpx; margin-top: -96rpx; }
.form {
  display: flex; flex-direction: column;
  background: var(--c-card); border-radius: var(--r-lg);
  padding: var(--sp-2) var(--sp-4) var(--sp-4);
  box-shadow: var(--sh-card);
}
.form-row { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.form-row:last-of-type { border-bottom: none; }
.label { width: 160rpx; color: var(--c-text-sub); font-size: 28rpx; }
.picker { flex: 1; color: var(--c-text); }
.input { flex: 1; text-align: right; }
.form button { margin-top: 48rpx; background: var(--c-primary-grad); }
.note { margin-top: 24rpx; font-size: 22rpx; color: var(--c-text-weak); text-align: center; line-height: 1.5; }
.forgot { text-align: center; margin-top: 32rpx; color: var(--c-text-weak); font-size: 26rpx; }
.link { color: var(--c-primary); }

/* 角色权限说明（RBAC 提示，与登录页一致） */
.role-desc { font-size: 22rpx; color: var(--c-info); background: var(--c-info-bg); padding: 14rpx 20rpx; border-radius: var(--r-md); margin: 4rpx 0 8rpx; }
