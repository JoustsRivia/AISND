/* pages/register/register.wxss —— 注册页（复用登录页视觉语言，公共类从 auth.wxss 引入） */
@import "/styles/auth.wxss";

/* 密码强度可视化 */
.pwd-strength { padding: 8rpx 0 4rpx; }
.pwd-bar { height: 12rpx; border-radius: 8rpx; background: var(--c-divider); overflow: hidden; }
.pwd-fill { height: 100%; border-radius: 8rpx; transition: width .2s ease, background .2s ease; }
.pwd-label { display: block; margin-top: 8rpx; font-size: 22rpx; }

/* R04 密码显隐切换 */
.pwd-field { position: relative; }
.pwd-eye { position: absolute; right: 4rpx; top: 50%; transform: translateY(-50%); font-size: 36rpx; padding: 8rpx; z-index: 2; }

/* 注册成功角色说明弹窗 */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,.45); display: flex; align-items: center; justify-content: center; z-index: 100; }
.modal { width: 560rpx; background: var(--c-card); border-radius: var(--r-lg); padding: 48rpx 40rpx; box-shadow: var(--sh-card); }
.modal-ico { font-size: 72rpx; text-align: center; }
.modal-title { text-align: center; font-size: 36rpx; font-weight: 700; color: var(--c-text); margin-top: 12rpx; }
.modal-sub { text-align: center; font-size: 24rpx; color: var(--c-text-weak); margin-top: 8rpx; }
.modal-role { margin: 32rpx 0; padding: 24rpx; background: var(--c-info-bg); border-radius: var(--r-md); }
.modal-role-tag { display: inline-block; font-size: 26rpx; font-weight: 600; color: var(--c-primary); }
.modal-role-tip { display: block; margin-top: 12rpx; font-size: 22rpx; color: var(--c-text-sub); line-height: 1.6; }
.modal button { margin-top: 8rpx; background: var(--c-primary-grad); }

/* 角色权限三段式说明（迭代 Item 6） */
.info-sec { margin-top: 18rpx; }
.info-h { display: block; font-size: 22rpx; color: var(--c-primary); font-weight: 600; margin-bottom: 6rpx; }
.info-b { display: block; font-size: 24rpx; color: var(--c-text-sub); line-height: 1.6; }
.info-li { display: block; }
.modal-link { margin-top: 20rpx; text-align: center; font-size: 24rpx; color: var(--c-primary); }
