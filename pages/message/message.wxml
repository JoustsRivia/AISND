<!-- pages/message/message.wxml —— 消息中心（M11） -->
<view wx:if="{{loading}}" class="loading">加载中…</view>
<block wx:else>
  <stats-card wx:if="{{stats.length}}" items="{{stats}}" columns="3" />

  <view class="bar">
    <filter-bar tabs="{{tabs}}" activeTab="{{activeTab}}" bind:tab="onTab" />
    <view class="bar-ops">
      <text wx:if="{{hasUnread && !batchMode}}" class="mark-all" bindtap="onMarkAll">全部已读</text>
      <text wx:if="{{!batchMode}}" class="sub" bindtap="onSubscribe">订阅推送</text>
      <text wx:if="{{!batchMode}}" class="gen" bindtap="onGenerate">生成预警</text>
      <text class="manage-btn {{batchMode ? 'on' : ''}}" bindtap="onToggleBatchMode">{{batchMode ? '取消' : '管理'}}</text>
    </view>
  </view>

  <view class="list">
    <view wx:for="{{list}}" wx:key="_id" class="msg lv-{{item._cls}} {{item.read ? 'read' : ''}}" data-id="{{item._id}}" bindtap="{{batchMode ? 'onCheckMsg' : 'onTap'}}">
      <view wx:if="{{batchMode}}" class="msg-check {{checkedIds.indexOf(item._id)>=0 ? 'checked' : ''}}"></view>
      <view wx:else class="msg-bar"></view>
      <view class="msg-main">
        <view class="msg-top">
          <text class="lv {{item._cls}}">{{item._icon}}</text>
          <text class="title">{{item.title}}</text>
          <text wx:if="{{!item.read}}" class="dot"></text>
        </view>
        <text class="content">{{item.content}}</text>
        <view wx:if="{{item.toolCode || item.orgName || item.keeperName}}" class="meta">
          <text wx:if="{{item.toolCode}}">器具 {{item.toolCode}}</text>
          <text wx:if="{{item.toolCode && (item.orgName || item.keeperName)}}"> | </text>
          <text wx:if="{{item.orgName}}">{{item.orgName}}</text>
          <text wx:if="{{item.orgName && item.keeperName}}"> | </text>
          <text wx:if="{{item.keeperName}}">{{item.keeperName}}</text>
        </view>
        <text wx:if="{{item._time}}" class="time">{{item._time}}</text>
      </view>
    </view>
    <view wx:if="{{!list.length}}" class="empty">
      <view class="empty-icon">📭</view>
      <view class="empty-title">暂无消息</view>
      <view class="empty-desc">试验预警与系统通知会显示在这里</view>
    </view>
  </view>

  <!-- #14 批量操作栏 -->
  <view wx:if="{{batchMode && list.length}}" class="batch-bar">
    <view class="batch-left">
      <text bindtap="onCheckAll">{{checkedIds.length === list.length ? '取消全选' : '全选'}}</text>
    </view>
    <view class="batch-right">
      <text bindtap="onBatchRead">批量已读</text>
      <text bindtap="onBatchDelete" class="batch-del">批量删除</text>
    </view>
  </view>
</block>
<view class="safe-bottom"></view>
