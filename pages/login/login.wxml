<!-- pages/login/login.wxml —— 登录页（hero 渐变头 + 上浮卡片，与主 tab 视觉统一） -->
<view class="login">
  <view class="hero login-hero">
    <view class="brand-sub">工器具安全管理平台</view>
    <view class="brand-title">善工智管</view>
  </view>

  <view class="form-wrap">
    <view class="form card">
      <!-- 模式切换：已注册走登录，新用户走注册 -->
      <view class="seg">
        <view class="seg-item {{mode==='login'?'seg-on':''}}" data-mode="login" bindtap="onMode">登录</view>
        <view class="seg-item {{mode==='register'?'seg-on':''}}" data-mode="register" bindtap="onMode">注册</view>
      </view>

      <!-- 注册专属：角色 + 单位 + 机构/班组（共享 role-org-picker 组件） -->
      <block wx:if="{{mode==='register'}}">
        <role-org-picker showRole="{{true}}" roles="{{roles}}" units="{{units}}" bind:change="onOrgPick" />
      </block>

      <form-field label="用户名" value="{{username}}" placeholder="请输入用户名" bind:input="onUserInput" />
      <view class="pwd-field">
        <form-field label="密码" password="{{!showPwd}}" value="{{password}}" placeholder="请输入密码" bind:input="onPwdInput" style="padding-right:64rpx" />
        <view class="pwd-eye" catchtap="togglePwd">{{showPwd ? '🙈' : '👁'}}</view>
      </view>
      <form-field wx:if="{{mode==='register'}}" label="昵称" value="{{nickname}}" placeholder="选填，默认同用户名" bind:input="onNickInput" />

      <button wx:if="{{mode==='login'}}" type="primary" loading="{{loading}}" bindtap="onLogin">登 录</button>
      <button wx:else type="primary" loading="{{loading}}" bindtap="onRegister">注册并登录</button>

      <view class="note">🔒 小程序管理员由系统后台指派；其余角色（含专班负责人 / 项目部负责人 / 安监部管理人员）均可自助注册</view>
      <view wx:if="{{mode==='login'}}" class="forgot" bindtap="onForgot">忘记密码？<text class="link">立即找回</text></view>
      <view class="forgot" bindtap="goRegister">没有账号？<text class="link">去注册</text></view>
    </view>
  </view>
</view>
