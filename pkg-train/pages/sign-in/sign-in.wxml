<!-- pkg-train/pages/sign-in/sign-in.wxml —— M9.2 我的培训 / 签到考核 -->
<view class="signin">
  <view wx:if="{{loading}}" class="muted center">加载中…</view>
  <block wx:else>
    <view wx:if="{{list.length === 0}}" class="muted center">暂无培训记录</view>
    <view wx:for="{{list}}" wx:key="_id" class="card train">
      <view class="row" style="justify-content: space-between;">
        <text class="t-title">{{item.courseTitle || '培训'}}</text>
        <status-tag status="{{item.status}}" text="{{item._statusText}}" size="sm" />
      </view>
      <view class="meta" wx:if="{{item.score !== undefined && item.score !== null}}">
        <text class="muted">成绩：{{item.score}}</text>
        <text class="muted">{{item.certified ? '已发证' : '未发证'}}</text>
      </view>
      <view wx:if="{{item.comment}}" class="meta">
        <text class="muted">评价：{{item.comment}}</text>
      </view>

      <!-- 操作按钮 -->
      <view class="actions">
        <button wx:if="{{item.status === 'assigned'}}" size="mini"
                data-item="{{item}}" catchtap="onConfirm">确认参训</button>
        <button wx:if="{{item.status === 'confirmed'}}" size="mini" type="primary"
                data-item="{{item}}" catchtap="onSignIn">签到考核</button>
        <button wx:if="{{isAdmin}}" size="mini" type="warn"
                data-item="{{item}}" catchtap="onComplete">标记完成</button>
      </view>
    </view>
  </block>
</view>

<!-- 评分弹窗 -->
<view wx:if="{{showEvalModal}}" class="modal-mask" catchtap="cancelEval">
  <view class="modal-box" catchtap="">
    <view class="modal-title">签到考核</view>
    <view wx:if="{{evalItem}}" class="muted modal-sub">{{evalItem.courseTitle || '培训'}}</view>

    <view class="field">
      <text class="label">成绩(0-100)</text>
      <input class="input" type="number" placeholder="请输入成绩"
             value="{{evalScore}}" bindinput="onScoreInput" />
    </view>
    <view class="field">
      <text class="label">评价</text>
      <textarea class="textarea" placeholder="选填"
                value="{{evalComment}}" bindinput="onCommentInput" />
    </view>

    <view class="modal-actions">
      <button size="mini" bindtap="cancelEval">取消</button>
      <button size="mini" type="primary" loading="{{submitting}}" bindtap="confirmEval">
        确认签到
      </button>
    </view>
  </view>
</view>
