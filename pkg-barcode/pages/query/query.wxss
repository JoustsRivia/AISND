/* pkg-barcode/pages/query/query.wxss —— R17 核验反馈 kv 列表样式 */

.kv-list {
  margin: var(--sp-2) 0;
  padding: var(--sp-2);
  background: var(--c-surface-2);
  border-radius: var(--r-sm);
}
.kv {
  display: flex;
  align-items: baseline;
  padding: 8rpx 0;
  border-bottom: 1rpx solid var(--c-divider);
}
.kv:last-child { border-bottom: none; }
.kv .k {
  width: 160rpx;
  flex-shrink: 0;
  font-size: var(--fs-sm);
  color: var(--c-text-muted);
}
.kv .v {
  flex: 1;
  font-size: var(--fs-md);
  color: var(--c-text);
  font-weight: 500;
}
