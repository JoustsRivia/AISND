/* components/user-picker/user-picker.wxss */
.user-picker {
  position: relative;
  width: 100%;
}

.up-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.up-input {
  flex: 1;
  height: 80rpx;
  padding: 0 60rpx 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.up-input:focus {
  background: #fff;
  border-color: #1677ff;
}

.up-clear {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.up-clear-icon {
  font-size: 24rpx;
  color: #999;
}

/* 下拉列表 */
.up-dropdown {
  position: absolute;
  left: 0;
  right: 0;
  top: 88rpx;
  max-height: 400rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.1);
  overflow-y: auto;
  z-index: 100;
}

.up-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.up-item:active {
  background: #f5f5f5;
}

.up-item:last-child {
  border-bottom: none;
}

.up-item-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.up-item-id {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 无结果提示 */
.up-no-result {
  padding: 20rpx 24rpx;
}

.up-no-result-text {
  font-size: 26rpx;
  color: #999;
}

/* 手动输入标记 */
.up-manual {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #fff7e6;
  border-radius: 8rpx;
  border-left: 4rpx solid #fa8c16;
}

.up-manual-text {
  font-size: 24rpx;
  color: #d46b08;
}
