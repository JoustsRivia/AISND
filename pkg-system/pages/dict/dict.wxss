/* pkg-system/pages/dict/dict.wxss */
.dict { padding-bottom: 40rpx; }
.title { font-size: 32rpx; font-weight: 600; }
.line { display: flex; align-items: center; justify-content: space-between; padding: 18rpx 0; border-bottom: 1rpx solid var(--c-divider); font-size: 28rpx; }
.name { font-size: 28rpx; }
.row.col { flex-direction: column; align-items: flex-start; }
.label { width: 100%; font-size: 26rpx; color: var(--c-text-weak); margin-top: 20rpx; }
.input { width: 100%; margin-top: 8rpx; font-size: 28rpx; border-bottom: 1rpx solid var(--c-divider); padding: 10rpx 0; }
.dict button { margin-top: 30rpx; background: var(--c-primary); }

/* #31 字典页布局修复：补齐系统页统一的标题行 / 操作按钮 flex 布局（原缺失导致按钮与列表错位） */
.title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.title-row .title { font-size: 32rpx; font-weight: 600; color: var(--c-text); }
.mini-btn { margin: 0; font-size: 24rpx; background: var(--c-bg); color: var(--c-text-sub); border: 1rpx solid var(--c-divider); }
.ops { display: flex; align-items: center; gap: 24rpx; }
.op { font-size: 26rpx; color: var(--c-primary); }
.op.danger { color: var(--c-danger); }
