<!-- pkg-system/pages/log/log.wxml —— M13.3 操作日志（增强：组合筛选 + CSV 导出） -->
<view class="log">
  <!-- 按类型筛选（后端 listLog 已支持 type） -->
  <view class="filters">
    <view
      wx:for="{{types}}" wx:key="value"
      class="chip {{activeType === item.value ? 'chip-on' : ''}}"
      data-type="{{item.value}}" bindtap="onFilter"
    >{{item.label}}</view>
  </view>

  <!-- 组合筛选：操作人 / 关键词 / 时间区间 -->
  <view class="filter-card">
    <view class="f-row">
      <input class="f-input" placeholder="操作人" value="{{operatorName}}" bindinput="onOpInput" />
      <input class="f-input" placeholder="关键词" value="{{keyword}}" bindinput="onKeywordInput" />
    </view>
    <view class="f-row">
      <picker mode="date" value="{{startTime}}" bindchange="onStartChange">
        <view class="f-picker">{{startTime || '起始日期'}}</view>
      </picker>
      <picker mode="date" value="{{endTime}}" bindchange="onEndChange">
        <view class="f-picker">{{endTime || '结束日期'}}</view>
      </picker>
    </view>
    <view class="f-actions">
      <button class="f-btn" size="mini" bindtap="onSearch">查询</button>
      <button class="f-btn ghost" size="mini" bindtap="onReset">重置</button>
      <button class="f-btn export" size="mini" bindtap="onExport">导出CSV</button>
    </view>
  </view>

  <view wx:if="{{!loading && !logs.length}}" class="empty">
    <view class="empty-icon">📜</view>
    <view class="empty-title">暂无操作日志</view>
    <view class="empty-desc">关键操作（入库/领用/报废/审批）将自动留痕</view>
  </view>

  <view class="card item" wx:for="{{logs}}" wx:key="_id">
    <view class="dot"></view>
    <view class="body">
      <view class="top">
        <text class="title">{{item.type || '操作'}}</text>
        <text class="time">{{item.time}}</text>
      </view>
      <text class="desc" wx:if="{{item.detail}}">{{item.detail}}</text>
      <text class="op">操作人：{{item.name}}</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中…</view>
  <view class="safe-bottom"></view>
</view>
