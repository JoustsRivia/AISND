/* pkg-system/pages/log/log.wxss —— M13.3 操作日志 */
.log { padding: var(--sp-3); }
/* 类型筛选 */
.filters { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: var(--sp-2); }
.chip {
  padding: 12rpx 28rpx; border-radius: 999rpx; font-size: 24rpx;
  color: var(--c-text-sub); background: var(--c-card);
  border: 1rpx solid var(--c-divider);
}
.chip-on { color: #fff; background: var(--c-primary); border-color: var(--c-primary); }
.card { background: var(--c-card); border-radius: var(--r-md); padding: var(--sp-3); margin-bottom: var(--sp-2); box-shadow: var(--sh-card); }
.item { display: flex; align-items: flex-start; }
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--c-primary); margin: 10rpx 20rpx 0 0; flex-shrink: 0; box-shadow: 0 0 0 6rpx var(--c-primary-soft); }
.body { flex: 1; min-width: 0; }
.top { display: flex; justify-content: space-between; align-items: baseline; }
.title { font-size: 28rpx; font-weight: 600; color: var(--c-text); }
.time { font-size: 22rpx; color: var(--c-text-weak); }
.desc { display: block; margin-top: 6rpx; font-size: 24rpx; color: var(--c-text-sub); }
.op { display: block; margin-top: 6rpx; font-size: 22rpx; color: var(--c-text-weak); }
.loading { text-align: center; }

/* 组合筛选卡片 */
.filter-card { background: var(--c-card); border-radius: var(--r-md); padding: var(--sp-2); margin-bottom: var(--sp-2); box-shadow: var(--sh-card); }
.f-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.f-row:last-of-type { margin-bottom: 0; }
.f-input, .f-picker {
  flex: 1; min-width: 0; height: 72rpx; line-height: 72rpx; padding: 0 24rpx;
  font-size: 26rpx; color: var(--c-text); background: var(--c-bg);
  border: 1rpx solid var(--c-divider); border-radius: var(--r-sm);
}
.f-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.f-btn { flex: 1; margin: 0; font-size: 26rpx; background: var(--c-primary); color: #fff; }
.f-btn.ghost { background: var(--c-bg); color: var(--c-text-sub); border: 1rpx solid var(--c-divider); }
.f-btn.export { background: var(--c-success, #1aad19); }

/* 服务端分页（迭代 Item 4） */
.pager { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; padding: 20rpx 8rpx 8rpx; }
.pager-info { font-size: 22rpx; color: var(--c-text-weak); }
.pager-btns { display: flex; gap: 16rpx; }
.p-btn { margin: 0; font-size: 24rpx; background: var(--c-bg); color: var(--c-text-sub); border: 1rpx solid var(--c-divider); }
.p-btn[disabled] { opacity: .5; }

