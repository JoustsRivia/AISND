/* pkg-scrap/pages/apply/apply.wxss —— R16 搜索选择器样式（仅页面局部） */

.search-bar {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  margin-top: var(--sp-1);
}
.search-input {
  flex: 1;
  background: var(--c-surface-2);
  border-radius: var(--r-sm);
  padding: 16rpx 20rpx;
  font-size: var(--fs-md);
  border: 1rpx solid var(--c-border);
}
.scan-btn {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  background: var(--c-primary-grad);
  color: #fff;
  border-radius: var(--r-sm);
  font-size: var(--fs-sm);
  font-weight: 600;
}

.search-dropdown {
  margin-top: var(--sp-1);
  background: var(--c-card);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-sm);
  box-shadow: var(--sh-card);
  max-height: 520rpx;
  overflow-y: auto;
}
.search-item {
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid var(--c-divider);
}
.search-item:last-child { border-bottom: none; }
.search-item:active { background: var(--c-surface); }
.si-main {
  font-size: var(--fs-md);
  color: var(--c-text);
  font-weight: 500;
}
.si-sub {
  font-size: var(--fs-xs);
  color: var(--c-text-muted);
  margin-top: 4rpx;
}

.sel-tool {
  margin-top: var(--sp-2);
  padding: 12rpx 16rpx;
  background: var(--c-success-bg);
  border-radius: var(--r-sm);
}
.sel-tool .label { color: var(--c-success); }
.sel-name {
  flex: 1;
  margin: 0 var(--sp-2);
  font-weight: 600;
  color: var(--c-text);
}
