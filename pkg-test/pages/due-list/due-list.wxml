<!-- pkg-test/pages/due-list/due-list.wxml —— M4.1.3 待检清单 -->
<view class="due">
  <view class="hint">到期前 15 天自动归集 · 超期自动标记禁用</view>

  <view wx:if="{{loading}}" class="muted card">加载中…</view>
  <view wx:for="{{list}}" wx:key="_id" class="card" data-id="{{item._id}}" bindtap="goSubmit">
    <view class="row" style="justify-content: space-between;">
      <text class="name">{{item.name}}</text>
      <text class="tag {{item.overdue ? 'tag-danger' : 'tag-warn'}}">{{item.overdue ? '超期' : '到期预警'}}</text>
    </view>
    <text class="muted">编号：{{item.code}} · {{item.category}}</text>
    <text class="muted">{{item.overdue ? '已超期' : '距到期'}} {{item.daysLeft}} 天 · 截止 {{item.expireAt}}</text>
  </view>
  <view wx:if="{{!loading && list.length === 0}}" class="muted card">暂无待检器具</view>
</view>
