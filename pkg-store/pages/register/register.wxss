/* pkg-store/pages/register/register.wxss */
.register { padding-bottom: 40rpx; }
.row { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid var(--c-divider); }
.row.col { flex-direction: column; align-items: flex-start; }
.label { width: 180rpx; font-size: 28rpx; }
.ipt { width: 100%; margin-top: 12rpx; font-size: 28rpx; }
.row:not(.col) .ipt { margin-top: 0; }
.picker-txt { font-size: 28rpx; color: var(--c-text, #333); }
.picker-txt.ph { color: var(--c-text-light, #999); }

/* R21 分区动态列表 */
.zones { width: 100%; }
.zone-item { display: flex; align-items: center; margin-top: 12rpx; }
.zone-ipt { flex: 1; margin-top: 0; }
.zone-del { margin-left: 16rpx; padding: 6rpx 16rpx; font-size: 24rpx; color: #e54d42; border: 1rpx solid #e54d42; border-radius: 8rpx; }
.add-zone { margin-top: 16rpx; font-size: 26rpx; color: var(--c-primary); }

.register button { margin-top: 40rpx; background: var(--c-primary); }

/* 已注册库房列表 */
.store-list { margin-top: 48rpx; padding: 0 32rpx; }
.store-header { font-size: 28rpx; font-weight: 700; color: var(--c-text); margin-bottom: 20rpx; padding-left: 8rpx; border-left: 6rpx solid var(--c-primary); }
.store-card { background: var(--c-card); border-radius: var(--r-md); padding: 24rpx; margin-bottom: 16rpx; box-shadow: var(--sh-card); }
.store-name { font-size: 30rpx; font-weight: 600; color: var(--c-text); margin-bottom: 8rpx; }
.store-meta { font-size: 24rpx; color: var(--c-text-sub); line-height: 1.6; }
.store-empty { margin-top: 48rpx; text-align: center; font-size: 26rpx; color: var(--c-text-weak); padding: 48rpx 0; }
