<!-- pkg-store/pages/register/register.wxml —— M3.1 库房注册 -->
<!-- R21：分区动态输入 + 组织两级 picker -->
<view class="register">
  <view class="card">
    <view class="row col"><text class="label">库房名称</text>
      <input class="ipt" placeholder="请输入库房名称" value="{{name}}" bindinput="bindName" />
    </view>

    <view class="row">
      <text class="label">所属单位</text>
      <picker class="ipt" mode="selector" range="{{units}}" range-key="name" value="{{unitIndex}}" bindchange="onUnitPick">
        <view class="picker-txt {{unitIndex >= 0 ? '' : 'ph'}}">{{unitIndex >= 0 ? units[unitIndex].name : '请选择单位'}}</view>
      </picker>
    </view>

    <view class="row">
      <text class="label">所属机构</text>
      <picker class="ipt" mode="selector" range="{{subOrgs}}" range-key="name" value="{{subIndex}}" bindchange="onSubPick" disabled="{{subOrgs.length === 0}}">
        <view class="picker-txt {{subIndex >= 0 ? '' : 'ph'}}">{{subIndex >= 0 ? subOrgs[subIndex].name : (subOrgs.length === 0 ? '（暂无项目部，将挂到单位）' : '请选择项目部')}}</view>
      </picker>
    </view>

    <view class="row col">
      <text class="label">分区</text>
      <view class="zones">
        <view class="zone-item" wx:for="{{zones}}" wx:key="index">
          <input class="ipt zone-ipt" placeholder="如：A区 / 绝缘区 / 电动区" value="{{item}}" data-index="{{index}}" bindinput="bindZone" />
          <view class="zone-del" data-index="{{index}}" bindtap="removeZone">删除</view>
        </view>
      </view>
      <view class="add-zone" bindtap="addZone">+ 添加分区</view>
    </view>

    <view class="row col"><text class="label">管理员</text>
      <input class="ipt" placeholder="请输入库房管理员姓名" value="{{keeper}}" bindinput="bindKeeper" />
    </view>
  </view>

  <button type="primary" loading="{{submitting}}" bindtap="onSubmit">提交注册</button>
</view>
